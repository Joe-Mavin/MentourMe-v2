# Core
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-cloudflare-pages-domain.pages.dev

# Select backend data store: 'sql' | 'firestore'
DATA_BACKEND=firestore

# Database sync gate (create-only when not production). On Cloud Run keep this off.
DB_SYNC=off

# Email (if used)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Firebase Admin SDK (optional when using Workload Identity on Cloud Run)
# If you deploy Cloud Run in the same GCP project as Firestore, you can omit these
# and rely on Application Default Credentials. If you set them, ensure proper escaping for newlines in the private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use bash-style escaping for newlines: replace real newlines with \n
FIREBASE_PRIVATE_KEY=
